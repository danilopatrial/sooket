# Required: used to encrypt stored API keys and variables at rest.
# Auto-generated into .env.local on first `npm run dev`/`npm start` if left unset.
ENCRYPTION_SECRET=change-me-to-a-random-string

# Optional: where to store the SQLite database (default: ./data/sooket.db)
# SOOKET_DATA_DIR=./data

# Optional: interface the server binds to (default: 127.0.0.1 / localhost-only).
# Sooket's management API has NO per-user auth — only widen this behind a trusted
# network, an authenticating reverse proxy, or with SOOKET_AUTH_TOKEN set (below).
# When bound to a non-loopback host without SOOKET_AUTH_TOKEN, Sooket prints a
# loud startup warning. See the Security section in README.
# SOOKET_HOST=0.0.0.0

# Optional: shared secret that gates the management API and dashboard. When set,
# every management request must present it as `Authorization: Bearer <token>`
# (programmatic) or unlock the dashboard once at /unlock (browser, sets a cookie).
# Leave unset for zero-friction local use. The execution API (/api/v1/chat),
# webhooks, and /api/health keep their own auth and are NOT gated by this.
# Use a long random value, e.g. `openssl rand -hex 32`.
# SOOKET_AUTH_TOKEN=

# Health checks (no env var needed; both are public/unauthenticated):
#   GET /api/health          -> liveness: { status, version, uptime, timestamp }
#   GET /api/health?ready=1   -> readiness: also probes the DB (read + write) and
#                                returns HTTP 503 with checks.db = "error" if the
#                                database is unreachable or read-only. Point Docker
#                                HEALTHCHECK / k8s readinessProbe at the ?ready=1 form.

# Optional: max request body size in bytes for /api/v1/chat and the webhook API
# (default: 1048576 = 1 MiB). Oversized requests are rejected with HTTP 413.
# SOOKET_MAX_BODY_BYTES=1048576

# Optional: value sent in the Access-Control-Allow-Origin header on the execution
# routes (/api/v1/chat and the webhook API). Defaults to "*". Pin it to a specific
# origin if you expose those routes to a browser.
# CORS_ORIGIN=https://myapp.com
