# Required: used to encrypt stored API keys and variables at rest.
# Auto-generated into .env.local on first `npm run dev`/`npm start` if left unset.
ENCRYPTION_SECRET=change-me-to-a-random-string

# Optional: where to store the SQLite database (default: ./data/sooket.db)
# SOOKET_DATA_DIR=./data

# Optional: interface the server binds to (default: 127.0.0.1 / localhost-only).
# Sooket has NO auth on its management API — only widen this behind a trusted
# network or an authenticating reverse proxy. See the Security section in README.
# SOOKET_HOST=0.0.0.0

# Optional: max request body size in bytes for /api/v1/chat and the webhook API
# (default: 1048576 = 1 MiB). Oversized requests are rejected with HTTP 413.
# SOOKET_MAX_BODY_BYTES=1048576

# Optional: value sent in the Access-Control-Allow-Origin header on the execution
# routes (/api/v1/chat and the webhook API). Defaults to "*". Pin it to a specific
# origin if you expose those routes to a browser.
# CORS_ORIGIN=https://myapp.com
