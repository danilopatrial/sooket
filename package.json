{
  "name": "sooket",
  "version": "0.1.1",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "node scripts/ensure-env.mjs",
    "dev": "node scripts/run-next.mjs dev",
    "build": "next build",
    "prestart": "node scripts/ensure-env.mjs",
    "start": "node scripts/run-next.mjs start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "setup": "npm install --ignore-scripts && npm rebuild --ignore-scripts sharp",
    "backup": "node -e \"const{cpSync,mkdirSync,existsSync}=require('fs'),p=process.env.SOOKET_DATA_DIR||'data',src=p+'/sooket.db';if(!existsSync(src)){console.error('No database at '+src);process.exit(1);}const ts=new Date().toISOString().replace(/[:.]/g,'-').slice(0,19),dst=p+'/sooket.db.bak-'+ts;cpSync(src,dst);console.log('Backup created: '+dst);\"",
    "execution-server": "node server/run.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@huggingface/transformers": "^4.2.0",
    "@types/sentiment": "^5.0.4",
    "@uiw/codemirror-theme-vscode": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.8.0",
    "franc-min": "^6.2.0",
    "gpt-tokenizer": "^3.4.0",
    "lucide-react": "^1.17.0",
    "nanoid": "^5.1.11",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sentiment": "^5.0.2",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "puppeteer@25.1.0": true,
    "protobufjs@7.6.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.0": true,
    "msw@2.14.6": true,
    "onnxruntime-node@1.24.3": true
  }
}
